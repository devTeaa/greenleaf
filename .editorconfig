# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{go,mod,sum}]
indent_style = tab

[Makefile]
indent_style = tab

[*.md]
# Trailing whitespace can be significant in Markdown (line breaks)
trim_trailing_whitespace = false
