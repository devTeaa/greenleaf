# Greenleaf production environment
# Generated by `pnpm setup` — edit manually if needed.

# ----- Storefront (Nuxt) -----
NUXT_PUBLIC_SITE_URL=https://greenleaf.example

# ----- CMS (Pocketbase) -----
# Admin UI lives at https://cms.greenleaf.example/_/
POCKETBASE_ADMIN_EMAIL=admin@greenleaf.example
POCKETBASE_ADMIN_PASSWORD=change-me-please
PB_ENCRYPTION_KEY=replace-with-32-char-hex-encryption-key

# ----- Pocketbase build arch -----
# Most VPS = amd64, Apple Silicon local dev / ARM VPS = arm64
PB_ARCH=amd64

# ----- Internal (set automatically in docker-compose) -----
# NUXT_PUBLIC_PAYLOAD_URL=http://cms:3001
